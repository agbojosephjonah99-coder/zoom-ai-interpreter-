# ── Recall.ai ─────────────────────────────────────────────────────────────────
# Get your API key at: https://www.recall.ai/
RECALL_API_KEY=your_recall_api_key_here

# ── OpenAI (Whisper STT + GPT-4o translation + TTS) ──────────────────────────
# ONE key covers everything: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── Webhook (your public server URL) ─────────────────────────────────────────
# Recall.ai sends transcripts here. For local dev use ngrok:
#   ngrok http 3000  →  copy the https URL below
# In production (Railway/Render) use your deployment URL
WEBHOOK_URL=https://your-ngrok-or-railway-url.com

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# Optional: choose a faster OpenAI translation model
# Default is gpt-4o-mini for lower latency.
OPENAI_TRANSLATION_MODEL=gpt-4o-mini

# Optional: customize the participant name shown in Zoom
# Keep this simple and emoji-free for better compatibility.
BOT_NAME=AI Interpreter
